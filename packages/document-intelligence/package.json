{
  "name": "@opentax/document-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "Pluggable document intelligence pipeline for OCR and LLM-driven extraction.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\""
  },
  "dependencies": {
    "@langchain/langgraph": "^1.3.2"
  }
}
